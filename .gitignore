# Python cache and virtual env
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/

# Notebook/runtime artifacts
.ipynb_checkpoints/
.mplconfig/

# Environment files
.env
.env.*

# Large raw data: ignore all
/data/raw/*

# Processed data: keep lightweight metadata/split files only
/data/processed/*
!/data/processed/DATA_DICTIONARY.md
!/data/processed/policy_meaning.csv
!/data/processed/train_policy_cell_samples.csv
!/data/processed/valid_policy_cell_samples.csv
!/data/processed/train_valid_hist_bins.csv
!/data/processed/train_valid_hist_stats.csv
!/data/processed/life_performance.csv
!/data/processed/train_valid_hist_compare.png
!/data/processed/charge_interval_features.csv
!/data/processed/discharge_interval_features.csv

# Generated outputs: ignore by default
/outputs/*

# Allow publishing analysis artifacts only
!/outputs/analysis/
/outputs/analysis/**
!/outputs/analysis/**/
!/outputs/analysis/**/*.csv
!/outputs/analysis/**/*.md
!/outputs/analysis/**/*.png
!/outputs/analysis/**/*.json

# Local collaboration docs (do not publish)
/AGENTS.md
/README_AI_STRUCTURE.md
/SCRIPT_CATALOG.md

# Local IDE settings
/.vscode/
